{
  "name": "visual-differ",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:client": "vite client --port 5173",
    "build:client": "vite build client",
    "dev": "concurrently \"npm:dev:client\" \"cross-env VDIFF_DEV=1 npm:start\"",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.bloomerang.visualdiffer",
    "productName": "Visual Differ",
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "package.json"
    ],
    "asar": false,
    "directories": { "output": "release" },
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "supertest": "^7.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
